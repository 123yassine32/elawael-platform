# ═══════════════════════════════════════
# .gitignore — ElAwail Digital Platform
# ═══════════════════════════════════════

# Fichiers système
.DS_Store
Thumbs.db
desktop.ini

# Éditeurs
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# Dépendances (si Node ajouté plus tard)
node_modules/

# Fichiers sensibles — NE JAMAIS COMMITER
.env
.env.local
*.key
secrets/

# Données confidentielles ElAwail — comptes, mots de passe, exports internes
comptes-elawail.csv
*.csv
reset-passwords.html
setup-accounts.html
generer-excel.html
diagnostic.html

# Builds temporaires
dist/
build/
.cache/

# Fichiers temporaires
*.tmp
*.temp

# Artefact généré par tools/check_js.js (regénéré à chaque vérification)
tools/extracted.js

# Livrables Word volumineux + fichiers de verrouillage Office
*.docx
~$*
