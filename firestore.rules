rules_version = '2';

// ===================================================================
// Regles de securite Firestore — ElAwail Platform
// Deployer via : firebase deploy --only firestore:rules
//
// Architecture des roles (CLAUDE.md §6) :
//   ADMIN        -> lecture + ecriture + suppression + gestion utilisateurs
//   GESTIONNAIRE -> lecture + ecriture (pas de suppression)
//   CONSULTANT   -> lecture seule (donnees sensibles masquees cote client)
//
// PRINCIPE : le role est stocke dans /users/{uid}.role
// Toute action est refusee par defaut (deny-by-default).
// ===================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Regle par defaut : tout refuser
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Fonctions utilitaires ---

    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getRole() == 'ADMIN';
    }

    function isAdminOrGestionnaire() {
      return isAuth() && getRole() in ['ADMIN', 'GESTIONNAIRE'];
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // --- Profils utilisateurs /users/{userId} ---
    // Chaque utilisateur lit/cree son propre profil (necessaire au premier login).
    // Seul un admin peut changer le champ 'role' ou supprimer un profil.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Creation : l'utilisateur peut creer SON propre document au premier login.
      // Il ne peut pas s'attribuer un role admin — seul isAdmin() peut le faire.
      allow create: if isOwner(userId) && !request.resource.data.keys().hasAny(['role'])
                    || isAdmin();

      // Mise a jour : le proprietaire peut tout modifier SAUF le champ 'role'.
      allow update: if isAdmin()
                    || (isOwner(userId)
                        && !request.resource.data.diff(resource.data)
                              .affectedKeys().hasAny(['role']));

      allow delete: if isAdmin();
    }

    // --- Donnees utilisateur /userData/{userId}/keys/{key} ---
    // Chaque educateur lit/ecrit uniquement ses propres donnees.
    // Admin et gestionnaire peuvent lire toutes les donnees.
    match /userData/{userId}/keys/{key} {
      allow read:   if isOwner(userId) || isAdminOrGestionnaire();
      allow write:  if isOwner(userId) || isAdminOrGestionnaire();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- Journal d'audit /audit_logs/{logId} ---
    // Lecture : tout utilisateur authentifie.
    // Creation : uniquement ses propres entrees (uid = auth.uid).
    // Modification et suppression INTERDITES — journal immuable.
    match /audit_logs/{logId} {
      allow read:   if isAuth();
      allow create: if isAuth()
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // --- Donnees globales partagees /shared/{doc} ---
    // Alertes, vacances, config — lecture par tous, ecriture admin/gestionnaire.
    match /shared/{doc} {
      allow read:   if isAuth();
      allow write:  if isAdminOrGestionnaire();
      allow delete: if isAdmin();
    }

  }
}
