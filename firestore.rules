rules_version = '2';
// ═══════════════════════════════════════════════════════════
// RÈGLES FIRESTORE — ElAwail Digital Platform
// CRITIQUE 2 (CLAUDE.md §4) — Sécurité des données
//
// À copier dans : Firebase Console → Firestore → Règles
// ═══════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Données personnelles par utilisateur ──────────────
    // Chaque éducateur/admin accède uniquement à ses propres données
    match /users/{uid}/{col}/{doc=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // ── Nouveaux bénéficiaires (partagés) ─────────────────
    // Tous les utilisateurs authentifiés peuvent lire/écrire
    match /org_new_benef/{doc} {
      allow read, write: if request.auth != null;
    }

    // ── Journal d'audit (partagé) ─────────────────────────
    match /audit_logs/{doc} {
      allow read, write: if request.auth != null;
    }

    // ── Refuser tout le reste ─────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
