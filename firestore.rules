rules_version = '2';

// ===================================================================
// RÈGLES FIRESTORE — ElAwail Digital Platform v3.5.1
// Fichier : firestore.rules
//
// DÉPLOIEMENT :
//   Option A : Firebase Console → Firestore → Règles (coller le contenu)
//   Option B : firebase deploy --only firestore:rules (Firebase CLI)
//
// ARCHITECTURE DES COLLECTIONS :
//   /users/{uid}                    → profil utilisateur (role, lastLogin)
//   /userData/{uid}/keys/{key}      → données sync localStorage
//   /userData/{uid}/bundles/{name}  → bundles PEI/ABLLS/Ghiyab
//   /org_new_benef/{docId}          → nouveaux bénéficiaires
//   /audit_logs/{logId}             → journal d'audit (immuable)
//   /org_shared/{doc}               → données partagées cadres↔admin
//                                     (présences, suivis, stages, entreprises…)
//   /rh_demandes/{id}               → demandes RH (congés, formations…)
//   /recommandations/{id}           → recommandations consultants
//   /shared/{doc}                   → données globales partagées (legacy)
//
// ROLES (CLAUDE.md §6) :
//   ADMIN        → tout voir + modifier + supprimer + gérer utilisateurs
//   GESTIONNAIRE → voir + modifier (pas de suppression, pas gestion users)
//   CONSULTANT   → lecture seule (PII masqués côté client)
//   EDUCATEUR    → accès uniquement à ses propres données
// ===================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Règle par défaut : tout refuser ──
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Fonctions utilitaires ──

    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getRole() == 'ADMIN';
    }

    function isAdminOrGestionnaire() {
      return isAuth() && getRole() in ['ADMIN', 'GESTIONNAIRE'];
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function getTeacherId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teacherId;
    }

    function isTeacherOf(teacherId) {
      return isAuth() && getTeacherId() == teacherId;
    }

    // ── Profils utilisateurs /users/{userId} ──
    // Chaque utilisateur lit/crée son propre profil.
    // Seul un admin peut modifier le champ 'role'.
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) && !request.resource.data.keys().hasAny(['role']))
                    || isAdmin();
      allow update: if isAdmin()
                    || (isOwner(userId)
                        && !request.resource.data.diff(resource.data)
                              .affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }

    // ── Données utilisateur /userData/{userId}/keys/{key} ──
    // Éducateur : accès exclusif à ses propres données.
    // Admin/Gestionnaire : peuvent lire toutes les données (rapports).
    match /userData/{userId}/keys/{key} {
      allow read:   if isOwner(userId) || isAdminOrGestionnaire();
      allow write:  if isOwner(userId) || isAdminOrGestionnaire();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ── Bundles de clés dynamiques /userData/{userId}/bundles/{bundleName} ──
    // Même règles que les clés simples.
    // Couvre : ea_pei_full_bundle, ea_ta9_bundle, ea_gh_bundle, ea_watha2iq_bundle
    match /userData/{userId}/bundles/{bundleName} {
      allow read:   if isOwner(userId) || isAdminOrGestionnaire();
      allow write:  if isOwner(userId) || isAdminOrGestionnaire();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ── Nouveaux bénéficiaires /org_new_benef/{docId} ──
    // Tout utilisateur authentifié peut ajouter.
    // Admin/Gestionnaire peuvent lire pour la vue globale.
    match /org_new_benef/{docId} {
      allow read:   if isAdminOrGestionnaire();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── Données PII bénéficiaires /beneficiaires/{docId} ──
    // Migration automatique par l'admin + chargement sécurisé par rôle.
    // Éducateur : accès en lecture/écriture à SES bénéficiaires uniquement.
    // Admin/Gestionnaire : accès complet.
    // Consultant : lecture seule (masquage PII géré côté client).
    match /beneficiaires/{docId} {
      allow read:   if isAdminOrGestionnaire()
                    || (isAuth() && getRole() == 'CONSULTANT')
                    || isTeacherOf(resource.data.teacherId);
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || isTeacherOf(resource.data.teacherId);
      allow delete: if isAdmin();
    }

    // ── Journal d'audit /audit_logs/{logId} ──
    // Lecture : tout utilisateur authentifié.
    // Création : uniquement ses propres entrées.
    // Modification et suppression INTERDITES — journal immuable.
    match /audit_logs/{logId} {
      allow read:   if isAuth();
      allow create: if isAuth()
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Données globales partagées /shared/{doc} (legacy) ──
    // Vacances, config, alertes globales.
    match /shared/{doc} {
      allow read:   if isAuth();
      allow write:  if isAdminOrGestionnaire();
      allow delete: if isAdmin();
    }

    // ── Données partagées cadres↔admin /org_shared/{doc} ──
    // Clé docId : "{teacherId}__{key}" ou "global__{key}".
    // Chaque cadre pousse ses données opérationnelles ; l'admin et le
    // gestionnaire consolident l'ensemble pour le pilotage.
    // Couvre : présences, suivis, rapports, notes, PEI, stages, entreprises…
    // (données opérationnelles agrégées — pas de PII brute ici).
    match /org_shared/{doc} {
      allow read:   if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Demandes RH /rh_demandes/{id} ──
    // Création par tout cadre authentifié pour ses propres demandes.
    // Lecture par tous (le cadre suit l'état de sa demande, l'admin les traite).
    // Mise à jour : admin/gestionnaire (validation) ou le cadre propriétaire.
    match /rh_demandes/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAdminOrGestionnaire()
                    || (isAuth() && resource.data.teacherId == getTeacherId());
      allow delete: if isAdmin();
    }

    // ── Recommandations consultants /recommandations/{id} ──
    // Saisies par les consultants/cadres, consultées par l'admin.
    match /recommandations/{id} {
      allow read:   if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Test de connectivité /_ping/{doc} ──
    // Simple vérification de la connexion Firestore.
    match /_ping/{doc} {
      allow read, write: if isAuth();
    }

  }
}
