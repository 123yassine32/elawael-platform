rules_version = '2';
// ═══════════════════════════════════════════════════════════════════
// RÈGLES FIRESTORE — ElAwail Digital Platform
// CLAUDE.md §4 Critique 1 — Sécurité maximale
//
// DÉPLOIEMENT :
//   Firebase Console → Firestore Database → Règles → Coller → Publier
//   OU : firebase deploy --only firestore:rules
//
// VERSION : 2.0 — Corrigé casse des rôles (ADMIN/GESTIONNAIRE)
// ═══════════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────

    // Vérifie que l'utilisateur est authentifié
    function isAuth() {
      return request.auth != null;
    }

    // Vérifie que l'utilisateur accède à ses propres données
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Récupère le rôle depuis Firestore — fallback 'EDUCATEUR' si absent
    function myRole() {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return doc.data.get('role', 'EDUCATEUR');
    }

    // Vérifie si l'utilisateur est admin (ADMIN en majuscules)
    function isAdmin() {
      return isAuth() && myRole() == 'ADMIN';
    }

    // Vérifie si l'utilisateur est admin ou gestionnaire
    function isAdminOrGestionnaire() {
      return isAuth() && (myRole() == 'ADMIN' || myRole() == 'GESTIONNAIRE');
    }

    // ── Profils utilisateurs ──────────────────────────────────────
    // Lecture : tout utilisateur authentifié
    // Écriture : chacun sur son propre doc OU admin sur tous les docs
    match /users/{uid} {
      allow read:  if isAuth();
      allow write: if isOwner(uid) || isAdmin();
    }

    // ── Synchronisation localStorage ↔ Firestore ─────────────────
    // Structure : userData/{uid}/keys/{clé}
    // Chaque utilisateur accède UNIQUEMENT à ses propres données
    match /userData/{uid}/keys/{key} {
      allow read, write: if isOwner(uid);
    }

    // ── Journal d'audit ───────────────────────────────────────────
    // Lecture : ADMIN + GESTIONNAIRE uniquement
    // Écriture : tout utilisateur authentifié (auto-enregistrement des actions)
    // Suppression : ADMIN uniquement
    match /audit_logs/{doc} {
      allow read:   if isAdminOrGestionnaire();
      allow create: if isAuth();
      allow update: if false;           // Journal immuable — jamais modifiable
      allow delete: if isAdmin();
    }

    // ── Demandes RH ───────────────────────────────────────────────
    // Lecture : ADMIN + GESTIONNAIRE
    // Écriture : tout utilisateur authentifié (soumettre une demande)
    match /rh_demandes/{doc} {
      allow read:  if isAdminOrGestionnaire();
      allow write: if isAuth();
    }

    // ── Recommandations pédagogiques ─────────────────────────────
    // Lecture + Écriture : tout utilisateur authentifié
    match /recommandations/{doc} {
      allow read, write: if isAuth();
    }

    // ── Ping Firebase (vérification connectivité) ─────────────────
    // Lecture uniquement pour détecter le statut en ligne/hors-ligne
    match /_ping/{doc} {
      allow read:  if isAuth();
      allow write: if false;
    }

    // ── Refuser TOUT le reste ─────────────────────────────────────
    // Sécurité par défaut : accès zéro aux collections non déclarées
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
